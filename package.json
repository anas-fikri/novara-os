{
  "name": "novara-os",
  "version": "0.1.0",
  "description": "Workspace-Oriented Intelligence Operating System CLI",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "novara": "./dist/index.js",
    "nos": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "novara": "node dist/index.js",
    "test": "node tests/e2e.test.js",
    "package": "npm run build && npm pack",
    "clean:dist": "rm -rf dist",
    "clean:keychain": "security delete-generic-password -a 'master-key' -s 'NovaraOS' || true",
    "clean:test-ws": "rm -rf test-workspace/.novara test-workspace/some-subfolder test-workspace/.novara/meeting_minutes.md test-workspace/.novara/bug_report.json test-workspace/.novara/state.json || true",
    "clean:all": "npm run clean:dist && npm run clean:keychain && npm run clean:test-ws"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
